model User {
  id        Int      @id @default(autoincrement())

  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile Profile?
  surgery Surgery[]
  @@map("users")
}

model Profile {
  id        Int      @id @default(autoincrement())
  bio       String?
  fullName String?
  phoneNumber String? 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
 user  User  @relation(fields: [userId], references: [id])
  userId    Int     @unique 
  @@map("profiles")
}

enum SurgeryStatus {
  SCHEDULED
  COMPLETED
  CANCELED
}

model Surgery {
  id           Int      @id @default(autoincrement())
  status      SurgeryStatus @default(SCHEDULED)
  description  String
   time   String?
   surgeryDate  String?
 surgeryType  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
 doctor   doctor  @relation(fields: [doctorId], references: [id])
  doctorId     Int
  user   User    @relation(fields: [userId], references: [id])
  userId       Int
@@map("surgeries")
}
